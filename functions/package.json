{
  "name": "auraprep-functions",
  "description": "Firebase Cloud Functions for AuraPrep Guardian Email System",
  "scripts": {
    "lint": "eslint .",
    "build": "tsc",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run serve",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "18"
  },
  "main": "lib/index.js",
  "dependencies": {
    "axios": "1.6.2",
    "firebase-admin": "11.11.0",
    "firebase-functions": "4.4.1",
    "jsonwebtoken": "8.5.1",
    "node-cron": "3.0.2",
    "nodemailer": "^9.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@types/nodemailer": "^8.0.1",
    "@typescript-eslint/eslint-plugin": "^6.8.0",
    "@typescript-eslint/parser": "^6.8.0",
    "eslint": "^8.50.0",
    "typescript": "^5.2.0"
  }
}
